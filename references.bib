    note = {ZSCC: 0000005},
    year = {2018},
    pages = {317--334},
    title = {{Propensity score methods for causal inference: an overview}},
    author = {Pan, Wei and Bai, Haiyan},
    number = {2},
    volume = {45},
    journal = {Behaviormetrika},
    abstract = {{Propensity score methods are popular and effective statistical techniques for reducing selection bias in observational data to increase the validity of causal inference based on observational studies in behavioral and social science research. Some methodologists and statisticians have raised concerns about the rationale and applicability of propensity score methods. In this review, we addressed these concerns by reviewing the development history and the assumptions of propensity score methods, followed by the fundamental techniques of and available software packages for propensity score methods. We especially discussed the issues in and debates about the use of propensity score methods. This review provides beneficial information about propensity score methods from the historical point of view and helps
researchers to select appropriate propensity score methods for their observational studies.}},
