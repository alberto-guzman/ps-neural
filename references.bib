@article{Guzman-Alvarez.2021,
    doi = {10.3102/01623737211001420},
    issn = {0162-3737},
    year = {2021},
    pages = {545--551},
    title = {{Disproportionate Burden: Estimating the Cost of FAFSA Verification for Public Colleges and Universities}},
    author = {Guzman-Alvarez, Alberto and Page, Lindsay C.},
    number = {3},
    volume = {43},
    journal = {Educational Evaluation and Policy Analysis},
    abstract = {{Verification is a federally mandated process that requires selected students to further attest that the information reported on their Free Application for Federal Student Aid (FAFSA) is accurate and complete. In this brief, we estimate institutional costs of administrating the FAFSA verification mandate and consider variation in costs by institution type and sector. Using data from 2014, we estimate that compliance costs to institutions in that year totaled nearly US\$500 million with the burden falling disproportionately on public institutions and community colleges, in particular. Specifically, we estimate that 22\% of an average community college's financial aid office operating budget is devoted to verification procedures, compared with 15\% at public 4-year institutions. Our analysis is timely, given
that rates of FAFSA verification have increased in recent years.}},
    local-url = {file://localhost/Users/albertoguzman-alvarez/Documents/Papers\%20Library/Educational\%20Evaluation\%20and\%20Policy\%20Analysis/Disproportionate\%20Burden-\%20Estimating\%20the\%20Cost\%20of\%20FAFSA\%20Verification\%20for\%20Public\%20Colleges\%20and\%20Universities\_2021\_Educational\%20Evaluation\%20and\%20Policy\%20Analysis\_1.pdf}}

